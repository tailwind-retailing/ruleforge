# RuleForge environment template
#
# Copy to `.env` (`cp .env.example .env`), fill in real values, then:
#   docker compose up -d
#
# Anything left unset uses defaults baked into the Dockerfile or compose file.

# ─── Caller-side auth (every API call needs this header) ──────────────
# Generate with: openssl rand -hex 24
# Sent as `X-AERO-Key: <value>` on every request to RuleForge.
RULEFORGE_API_KEY=

# ─── DocumentForge backing store auth (when RULE_SOURCE=df) ──────────
# Bearer token used by RuleForge to call DocumentForge.
# Must match DFDB_API_KEY of the dfdb instance you point at.
# Generate with: openssl rand -hex 24
RULEFORGE_DF_API_KEY=

# ─── Source mode ─────────────────────────────────────────────────────
# `df`     — load rules from a DocumentForge instance (default)
# `local`  — load rules from JSON files baked into the image / mounted volume
RULEFORGE_RULE_SOURCE=df

# ─── DocumentForge connection (when RULE_SOURCE=df) ──────────────────
# Default in compose points at the sibling `documentforge` service.
# Override to talk to an external DF (e.g. https://dfdb.example.com).
# RULEFORGE_DF_BASE_URL=http://documentforge:5000

# ─── Multi-tenant namespacing (optional) ─────────────────────────────
# Prefix added to every collection name in DocumentForge.
# Useful if multiple ruleforge environments share one dfdb.
# RULEFORGE_COLLECTION_PREFIX=prod_

# ─── Environment label (optional) ────────────────────────────────────
# Used in logs and the /admin/bindings response.
# RULEFORGE_ENV=production

# ─── Local file source (only used when RULE_SOURCE=local) ────────────
# RULEFORGE_FIXTURES_DIR=/app/fixtures
# RULEFORGE_REFS_DIR=/app/refs
