{
  "id": "rule-bag-policy",
  "name": "Bag policy · Economy LHR–DXB (slice 2, with bag-pieces filter)",
  "description": "Cabin=Y AND orig=LHR AND requested bagPieces between 1 and 4 (inclusive) ⇒ apply bag allowance.",
  "tags": ["ancillary", "bag", "slice-2"],
  "category": "Ancillary",
  "endpoint": "/v1/ancillary/bag-policy",
  "method": "POST",
  "status": "published",
  "currentVersion": 3,
  "inputSchema": {
    "type": "object",
    "properties": {
      "pnr":   { "type": "string" },
      "cabin": { "type": "string" },
      "orig":  { "type": "string" },
      "dest":  { "type": "string" },
      "pax":   { "type": "array" },
      "bagPieces": { "type": "integer" }
    },
    "required": ["cabin", "orig"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "ruleId":      { "type": "string" },
      "ruleVersion": { "type": "integer" },
      "decision":    { "type": "string", "enum": ["apply", "skip", "error"] },
      "evaluatedAt": { "type": "string", "format": "date-time" },
      "result":      { "type": "object" },
      "trace":       { "type": "array" }
    }
  },
  "nodes": [
    {
      "id": "n1-input",
      "type": "input",
      "position": { "x": 40, "y": 200 },
      "data": { "label": "Request", "category": "input" }
    },
    {
      "id": "n2-cabin",
      "type": "filter",
      "position": { "x": 280, "y": 100 },
      "data": {
        "label": "Cabin · Economy",
        "category": "filter",
        "templateId": "sys-filter-str",
        "config": {
          "source":  { "kind": "request", "path": "$.cabin" },
          "compare": { "operator": "equals", "value": "Y", "caseInsensitive": true, "trim": true },
          "arraySelector": "first",
          "onMissing": "fail"
        }
      }
    },
    {
      "id": "n3-orig",
      "type": "filter",
      "position": { "x": 280, "y": 220 },
      "data": {
        "label": "Origin · LHR",
        "category": "filter",
        "templateId": "sys-filter-str",
        "config": {
          "source":  { "kind": "request", "path": "$.orig" },
          "compare": { "operator": "in", "values": ["LHR"], "caseInsensitive": true, "trim": true },
          "arraySelector": "first",
          "onMissing": "fail"
        }
      }
    },
    {
      "id": "n4-bagpieces",
      "type": "filter",
      "position": { "x": 280, "y": 340 },
      "data": {
        "label": "Bag pieces · 1–4",
        "category": "filter",
        "templateId": "sys-filter-num",
        "config": {
          "source":  { "kind": "request", "path": "$.bagPieces" },
          "compare": { "operator": "between", "min": 1, "max": 4, "minInclusive": true, "maxInclusive": true },
          "arraySelector": "first",
          "onMissing": "pass"
        }
      }
    },
    {
      "id": "n5-and",
      "type": "logic",
      "position": { "x": 540, "y": 220 },
      "data": { "label": "AND", "category": "logic", "templateId": "sys-and" }
    },
    {
      "id": "n6-output",
      "type": "output",
      "position": { "x": 800, "y": 220 },
      "data": {
        "label": "Result",
        "category": "output",
        "config": {
          "result": {
            "code": "BAG",
            "pieces": 2,
            "weightKg": 23,
            "fee": 0,
            "currency": "AED"
          }
        }
      }
    }
  ],
  "edges": [
    { "id": "e1", "source": "n1-input", "target": "n2-cabin",    "branch": "default" },
    { "id": "e2", "source": "n1-input", "target": "n3-orig",     "branch": "default" },
    { "id": "e3", "source": "n1-input", "target": "n4-bagpieces", "branch": "default" },
    { "id": "e4", "source": "n2-cabin",     "target": "n5-and", "branch": "pass" },
    { "id": "e5", "source": "n3-orig",      "target": "n5-and", "branch": "pass" },
    { "id": "e6", "source": "n4-bagpieces", "target": "n5-and", "branch": "pass" },
    { "id": "e7", "source": "n5-and",      "target": "n6-output", "branch": "pass" }
  ],
  "updatedAt": "2026-04-27T13:00:00.000Z",
  "updatedBy": "slice-2-bootstrap"
}
