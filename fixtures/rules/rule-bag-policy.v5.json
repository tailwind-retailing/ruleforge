{
  "id": "rule-bag-policy",
  "name": "Bag policy · slice 3b (sub-rule + product + assembly)",
  "description": "cabin=Y AND orig=LHR ⇒ apply bag, with a tier-bonus sub-rule adding bonusPieces to ctx.tierUplift; output assembled from the product node and ctx.tierUplift via ${ctx.tierUplift} placeholders.",
  "tags": ["ancillary", "bag", "slice-3b"],
  "category": "Ancillary",
  "endpoint": "/v1/ancillary/bag-policy",
  "method": "POST",
  "status": "published",
  "currentVersion": 5,
  "inputSchema": {
    "type": "object",
    "properties": {
      "pnr":   { "type": "string" },
      "cabin": { "type": "string" },
      "orig":  { "type": "string" },
      "dest":  { "type": "string" },
      "pax":   { "type": "array" }
    },
    "required": ["cabin", "orig", "pax"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "ruleId":      { "type": "string" },
      "ruleVersion": { "type": "integer" },
      "decision":    { "type": "string", "enum": ["apply", "skip", "error"] },
      "evaluatedAt": { "type": "string", "format": "date-time" },
      "result":      { "type": "object" },
      "trace":       { "type": "array" },
      "durationMs":  { "type": "integer" }
    }
  },
  "contextSchema": {
    "type": "object",
    "properties": { "tierUplift": { "type": "integer" } }
  },
  "nodes": [
    {
      "id": "n1-input", "type": "input",
      "position": { "x": 40, "y": 220 },
      "data": { "label": "Request", "category": "input" }
    },
    {
      "id": "n2-cabin", "type": "filter",
      "position": { "x": 280, "y": 100 },
      "data": {
        "label": "Cabin · Economy", "category": "filter", "templateId": "sys-filter-str",
        "config": {
          "source":  { "kind": "request", "path": "$.cabin" },
          "compare": { "operator": "equals", "value": "Y", "caseInsensitive": true, "trim": true },
          "arraySelector": "first", "onMissing": "fail"
        }
      }
    },
    {
      "id": "n3-orig", "type": "filter",
      "position": { "x": 280, "y": 240 },
      "data": {
        "label": "Origin · LHR", "category": "filter", "templateId": "sys-filter-str",
        "config": {
          "source":  { "kind": "request", "path": "$.orig" },
          "compare": { "operator": "in", "values": ["LHR"], "caseInsensitive": true, "trim": true },
          "arraySelector": "first", "onMissing": "fail"
        }
      }
    },
    {
      "id": "n4-and", "type": "logic",
      "position": { "x": 540, "y": 170 },
      "data": { "label": "AND", "category": "logic", "templateId": "sys-and" }
    },
    {
      "id": "n5-tier", "type": "ruleRef",
      "position": { "x": 800, "y": 80 },
      "data": {
        "label": "Tier uplift",
        "category": "ruleRef",
        "templateId": "sys-rule-ref",
        "subRuleCall": {
          "ruleId": "rule-tier-bonus",
          "inputMapping":  { "pax": "$.pax" },
          "outputMapping": { "ctx.tierUplift": "result.bonusPieces" },
          "onError": "default",
          "defaultValue": { "bonusPieces": 0, "bonusKg": 0 },
          "pinnedVersion": 1
        },
        "writesContext": ["tierUplift"]
      }
    },
    {
      "id": "n6-bag", "type": "product",
      "position": { "x": 800, "y": 260 },
      "data": {
        "label": "Bag · base 2×23kg + tier uplift", "category": "product", "templateId": "cus-bag",
        "readsContext": ["tierUplift"],
        "config": {
          "output": {
            "code": "BAG",
            "pieces": 2,
            "weightKg": 23,
            "fee": 0,
            "currency": "AED",
            "bonusPieces": "${ctx.tierUplift}"
          }
        }
      }
    },
    {
      "id": "n7-output", "type": "output",
      "position": { "x": 1060, "y": 200 },
      "data": { "label": "Result", "category": "output" }
    }
  ],
  "edges": [
    { "id": "e1",  "source": "n1-input",  "target": "n2-cabin", "branch": "default" },
    { "id": "e2",  "source": "n1-input",  "target": "n3-orig",  "branch": "default" },
    { "id": "e3",  "source": "n2-cabin",  "target": "n4-and",   "branch": "pass" },
    { "id": "e4",  "source": "n3-orig",   "target": "n4-and",   "branch": "pass" },
    { "id": "e5",  "source": "n4-and",    "target": "n5-tier",  "branch": "pass" },
    { "id": "e6",  "source": "n4-and",    "target": "n6-bag",   "branch": "pass" },
    { "id": "e7",  "source": "n5-tier",   "target": "n6-bag",   "branch": "default" },
    { "id": "e8",  "source": "n6-bag",    "target": "n7-output","branch": "default" }
  ],
  "updatedAt": "2026-04-27T14:30:00.000Z",
  "updatedBy": "slice-3b-bootstrap"
}
