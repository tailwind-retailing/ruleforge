{
  "id": "rule-bag-policy",
  "name": "Bag policy · slice 3c (mutators + ref-set lookup)",
  "description": "cabin=Y AND orig=LHR ⇒ bag product, then lookup-replace fee from ref-price-matrix, then set-property markup.",
  "tags": ["ancillary", "bag", "slice-3c"],
  "category": "Ancillary",
  "endpoint": "/v1/ancillary/bag-policy",
  "method": "POST",
  "status": "published",
  "currentVersion": 6,
  "inputSchema": {
    "type": "object",
    "properties": {
      "pnr":       { "type": "string" },
      "cabin":     { "type": "string" },
      "orig":      { "type": "string" },
      "dest":      { "type": "string" },
      "route":     { "type": "string" },
      "bagPieces": { "type": "integer" }
    },
    "required": ["cabin", "orig", "dest", "bagPieces"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "ruleId":      { "type": "string" },
      "ruleVersion": { "type": "integer" },
      "decision":    { "type": "string", "enum": ["apply", "skip", "error"] },
      "evaluatedAt": { "type": "string", "format": "date-time" },
      "result":      { "type": "object" },
      "trace":       { "type": "array" },
      "durationMs":  { "type": "integer" }
    }
  },
  "nodes": [
    {
      "id": "n1-input", "type": "input",
      "position": { "x": 40, "y": 220 },
      "data": { "label": "Request", "category": "input" }
    },
    {
      "id": "n2-cabin", "type": "filter",
      "position": { "x": 280, "y": 100 },
      "data": {
        "label": "Cabin · Economy", "category": "filter", "templateId": "sys-filter-str",
        "config": {
          "source":  { "kind": "request", "path": "$.cabin" },
          "compare": { "operator": "equals", "value": "Y", "caseInsensitive": true, "trim": true },
          "arraySelector": "first", "onMissing": "fail"
        }
      }
    },
    {
      "id": "n3-orig", "type": "filter",
      "position": { "x": 280, "y": 240 },
      "data": {
        "label": "Origin · LHR", "category": "filter", "templateId": "sys-filter-str",
        "config": {
          "source":  { "kind": "request", "path": "$.orig" },
          "compare": { "operator": "in", "values": ["LHR"], "caseInsensitive": true, "trim": true },
          "arraySelector": "first", "onMissing": "fail"
        }
      }
    },
    {
      "id": "n4-and", "type": "logic",
      "position": { "x": 540, "y": 170 },
      "data": { "label": "AND", "category": "logic", "templateId": "sys-and" }
    },
    {
      "id": "n5-bag", "type": "product",
      "position": { "x": 800, "y": 170 },
      "data": {
        "label": "Bag · base 23kg", "category": "product", "templateId": "cus-bag",
        "config": {
          "output": {
            "code":     "BAG",
            "weightKg": 23,
            "currency": "AED",
            "fee":      0,
            "pieces":   0
          }
        }
      }
    },
    {
      "id": "n6-pieces", "type": "mutator",
      "position": { "x": 800, "y": 60 },
      "data": {
        "label": "Set pieces from request", "category": "mutator", "templateId": "sys-set",
        "config": {
          "target": "pieces",
          "from":   "$.bagPieces"
        }
      }
    },
    {
      "id": "n7-fee", "type": "mutator",
      "position": { "x": 1060, "y": 170 },
      "data": {
        "label": "Lookup fee in price matrix", "category": "mutator", "templateId": "cus-price-lookup",
        "config": {
          "target": "fee",
          "lookup": {
            "referenceId": "ref-price-matrix",
            "valueColumn": "fee",
            "matchOn": {
              "route":  "$.route",
              "cabin":  "$.cabin",
              "pieces": "$.bagPieces"
            }
          },
          "onMissing": "leave"
        }
      }
    },
    {
      "id": "n8-output", "type": "output",
      "position": { "x": 1320, "y": 170 },
      "data": { "label": "Result", "category": "output" }
    }
  ],
  "edges": [
    { "id": "e1", "source": "n1-input",  "target": "n2-cabin", "branch": "default" },
    { "id": "e2", "source": "n1-input",  "target": "n3-orig",  "branch": "default" },
    { "id": "e3", "source": "n2-cabin",  "target": "n4-and",   "branch": "pass" },
    { "id": "e4", "source": "n3-orig",   "target": "n4-and",   "branch": "pass" },
    { "id": "e5", "source": "n4-and",    "target": "n5-bag",   "branch": "pass" },
    { "id": "e6", "source": "n5-bag",    "target": "n6-pieces","branch": "default" },
    { "id": "e7", "source": "n6-pieces", "target": "n7-fee",   "branch": "default" },
    { "id": "e8", "source": "n7-fee",    "target": "n8-output","branch": "default" }
  ],
  "updatedAt": "2026-04-27T15:00:00.000Z",
  "updatedBy": "slice-3c-bootstrap"
}
